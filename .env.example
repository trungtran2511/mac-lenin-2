# Current client-side Gemini configuration used by src/lib/ai.ts.
# VITE_* values are embedded in the browser bundle; do not treat them as secrets.
VITE_GEMINI_API_KEY=AIza_your_primary_google_ai_studio_key_here
VITE_GEMINI_API_KEY1=AIza_your_first_backup_google_ai_studio_key_here
VITE_GEMINI_API_KEY2=AIza_your_second_backup_google_ai_studio_key_here
VITE_GEMINI_MODEL=gemini-2.5-flash

# Optional Vercel serverless route in api/chat.js. The main App chat does not
# use this route by default. Use it only after moving client calls server-side.
# GEMINI_API_KEY=AIza_your_server_side_google_ai_studio_key_here
# GEMINI_MODEL=gemini-2.5-flash
